---
import { LOCALES, DEFAULT_LIST, type Locale } from "@/lib/types"
import ListView from "@/layouts/ListView.astro"

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }))
}

const locale = Astro.params.locale as Locale
---
<ListView locale={locale} list={DEFAULT_LIST} />
