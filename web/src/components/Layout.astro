---
import type { Locale } from "@/lib/types"
import "@/styles/global.css"

interface Props {
  locale: Locale
  title: string
  canonical: string
  ogImage?: string
  /** Active genre slug; sets data-genre on <body> so --genre-primary resolves
      page-wide (the now-line and any other genre-tinted chrome read it). */
  genre: string
}

const { locale, title, canonical, ogImage, genre } = Astro.props
const canonicalUrl = new URL(canonical, Astro.site)
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined
---
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl.href} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    {ogImageUrl && (
      <>
        <meta property="og:image" content={ogImageUrl} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:image" content={ogImageUrl} />
      </>
    )}
    <script is:inline>
      if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
        document.documentElement.classList.add("dark");
      }
      window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
        document.documentElement.classList.toggle("dark", e.matches);
      });
    </script>
    <script defer src="https://umm.july.dev/script.js" data-website-id="8caba607-9ee5-4b3a-aba8-7d4f7a06b75e"></script>
  </head>
  <body data-genre={genre} class="font-sans bg-background text-foreground">
    <slot />
    <script>
      // One full-bleed grid. JS computes only integers: how many whole
      // columns fit, the content band width in cells (≈1300px), and the
      // band's start column snapped so it's centered to the nearest cell
      // (so the band always lands exactly on gridlines).
      const BAND_PX = 1300;
      function syncGrid() {
        document.querySelectorAll<HTMLElement>(".gridpaper").forEach((grid) => {
          // Round the cell to a whole pixel so grid tracks and the
          // background-image lines sit on identical integer boundaries and
          // can't drift apart across many columns (sub-pixel track widths
          // were the source of the misalignment).
          const base = parseFloat(getComputedStyle(grid).getPropertyValue("--font-size")) || 16;
          const width = grid.clientWidth;
          const cellMultiplier = parseFloat(getComputedStyle(grid).getPropertyValue("--cell-multiplier")) || 1.8
          const target = Math.round(base * cellMultiplier);

          // Mobile (≤640px): no centered band — the content fills the full
          // width. Pick the whole number of cells that fits at the ~32px target,
          // then grow the cell so gridCols × cell === width exactly. The grid
          // tracks and the background-image lines both read this same --cell, so
          // they stay aligned by construction and no sub-cell sliver is left on
          // the right. (cell is fractional here, which is fine: track width and
          // line spacing are identical, so they can't drift apart.)
          let cell, gridCols, bandCells, colStart;
          if (width <= 640) {
            gridCols = Math.max(1, Math.floor(width / target));
            cell = width / gridCols;
            bandCells = gridCols;
            colStart = 1;
          } else {
            // Desktop: fixed square cell, centered band snapped to gridlines.
            cell = target;
            gridCols = Math.max(1, Math.floor(width / cell));
            bandCells = Math.min(gridCols, Math.max(20, Math.round(BAND_PX / cell)));
            colStart = Math.max(1, Math.round((gridCols - bandCells) / 2) + 1);
          }
          grid.style.setProperty("--cell", `${cell}px`);
          grid.style.setProperty("--grid-cols", String(gridCols));
          grid.style.setProperty("--band-cells", String(bandCells));
          grid.style.setProperty("--col-start", String(colStart));

          // Film masonry columns, chosen LOGICALLY from how many whole cells
          // the band actually has — not a guessed pixel breakpoint (a CSS
          // @media query can't read --band-cells). Cards SCALE to fill the band:
          // with `cols` columns and a 2-cell gutter between them, each card is
          // floor((bandCells − 2·(cols−1)) / cols) cells wide. Pick the most
          // columns that keep a card ≥ MIN_CARD cells, so a narrower band drops
          // to 2 (then 1) columns instead of overflowing. data-film-cols selects
          // which build-time packing (col3/col2/col1) the CSS reads; --film-width
          // / --film-stride feed the scaled geometry to the cards.
          const MIN_CARD = 10;
          const GUTTER = 2;
          let filmCols = 1;
          let cardW = bandCells;
          for (const c of [3, 2]) {
            const w = Math.floor((bandCells - GUTTER * (c - 1)) / c);
            if (w >= MIN_CARD) {
              filmCols = c;
              cardW = w;
              break;
            }
          }
          grid.dataset.filmCols = String(filmCols);
          grid.style.setProperty("--film-width", String(cardW));
          grid.style.setProperty("--film-stride", String(cardW + GUTTER));
        });
        // Let dependents (e.g. the navbar's cell-snapping) recompute once the
        // grid's --cell/--col-start are settled for this pass.
        window.dispatchEvent(new Event("gridsync"));
      }
      // Exposed so the film view toggle can re-sync a tree that was display:none
      // at first paint (a hidden .gridpaper has clientWidth 0, so it would keep
      // --cell:0px and render invisible until the next resize).
      (window as any).syncGrid = syncGrid;
      syncGrid();
      window.addEventListener("resize", syncGrid);
      window.addEventListener("load", syncGrid);
    </script>
    <script>
      // Time-aware agenda. Runs on load and whenever the tab is refocused, so a
      // page left open overnight self-corrects. Reasons in the same "logical
      // day" frame as src/lib/agenda.ts: the 05:00 boundary means events at
      // 00:00–04:59 belong to the PREVIOUS evening's section, so section
      // data-date is a *logical* date and we must compare "now" the same way.

      // Mirror agenda.ts timeSortKey: empty first, then ≥05:00, then post-midnight last.
      function timeSortKey(t: string): string {
        if (t === "") return "0";
        if (t >= "05:00") return "1" + t;
        return "2" + t;
      }

      // Local yyyy-mm-dd (NOT toISOString, which shifts to UTC and can lose a
      // day). Section data-date values are local calendar dates, so "now" must
      // be expressed the same way.
      function localDateStr(d: Date): string {
        const y = d.getFullYear();
        const m = String(d.getMonth() + 1).padStart(2, "0");
        const day = String(d.getDate()).padStart(2, "0");
        return `${y}-${m}-${day}`;
      }

      function syncAgenda() {
        const now = new Date();
        const hhmm = now.toTimeString().slice(0, 5);
        const isPostMidnight = hhmm < "05:00";
        // Logical "today": calendar date, rolled back one day before 05:00.
        const nowLogicalDate = localDateStr(
          new Date(now.getFullYear(), now.getMonth(), now.getDate() - (isPostMidnight ? 1 : 0)),
        );
        const nowKey = timeSortKey(hhmm);

        document.querySelectorAll<HTMLElement>(".now-line").forEach((el) => el.remove());

        // Sort key for "2 hours ago" on the wall clock. Subtracting on the Date
        // wraps midnight correctly; timeSortKey then maps it into the same
        // logical-day ordering the rows use (post-midnight sorts last). Only
        // applied to the current logical day, so a 23:00 cutoff after midnight
        // never reaches into a future day's evening.
        const cutoff = new Date(now.getTime() - 2 * 60 * 60 * 1000);
        const cutoffKey = timeSortKey(cutoff.toTimeString().slice(0, 5));

        document.querySelectorAll<HTMLElement>("section[data-date]").forEach((section) => {
          const date = section.dataset.date ?? "";
          section.hidden = false;
          section.querySelectorAll<HTMLElement>("[data-time]").forEach((row) => {
            row.hidden = false;
          });
          // Drop any prior early-screenings toggle; renumbering below recreates it.
          section.querySelector(".gc-early-toggle")?.remove();

          if (date < nowLogicalDate) {
            // Fully past logical days hidden (also heals a stale build).
            section.hidden = true;
            return;
          }
          if (date === nowLogicalDate) {
            // Film time-view only: collapse the leading run of screenings that
            // started >2h ago behind a "show earlier" toggle (unless the user
            // expanded this section). Renumbering --ev keeps the explicit grid
            // gap-free. Other lists/views show everything.
            const earlyHide = section.closest("[data-early-hide]");
            if (earlyHide && !section.querySelector("[data-film-card]")) {
              applyEarlyHide(section, earlyHide as HTMLElement, cutoffKey);
            }
            // Keep every (remaining) event visible — even after midnight, when
            // the evening's ≥05:00 events are all past — and draw the now-marker.
            // nowKey sorts post-midnight times last, so after midnight every
            // ≥05:00 row reads as past and the marker lands at the end.
            if (section.querySelector("[data-film-card]")) {
              drawFilmNowDots(section, nowKey);
            } else {
              drawNowLine(section, nowKey);
            }
          }
        });

        // Mark the first *visible* day in each view so CSS can drop its top
        // breathing space (the first day sits right under the options panel).
        // Past days are merely hidden, not removed, so :first-of-type in CSS
        // would wrongly match a hidden past section — do it here instead.
        document
          .querySelectorAll<HTMLElement>("[data-first-day]")
          .forEach((el) => el.removeAttribute("data-first-day"));
        document
          .querySelectorAll<HTMLElement>("[data-film-view]")
          .forEach((view) => {
            const first = [...view.querySelectorAll<HTMLElement>("section[data-date]")].find(
              (s) => !s.hidden,
            );
            first?.setAttribute("data-first-day", "");
          });
      }

      // Collapse the leading run of screenings that started >2h ago (cutoffKey)
      // behind a "show earlier screenings" toggle row. Rows are chronological,
      // so the hidden ones are always a contiguous block at the top — no interior
      // gap. The grid places rows at explicit lines via --ev, so hiding rows
      // means renumbering the survivors (and the spacer) to pack them gap-free.
      // The toggle occupies the top visible row; clicking it sets data-show-early
      // and re-runs syncAgenda, which then shows everything.
      function applyEarlyHide(section: HTMLElement, root: HTMLElement, cutoffKey: string) {
        const rows = [...section.querySelectorAll<HTMLElement>(".contents[data-time]")];
        if (rows.length === 0) return;

        const expanded = section.hasAttribute("data-show-early");
        // Count the leading run of >2h-past rows. Stop at the first still-recent
        // row so we never hide something in the middle.
        let nEarly = 0;
        for (const row of rows) {
          if (timeSortKey(row.dataset.time ?? "") < cutoffKey) nEarly += 1;
          else break;
        }
        // Nothing early, or everything is early (don't hide a whole day — there'd
        // be only the toggle left): show all, plain numbering.
        if (nEarly === 0 || nEarly === rows.length || expanded) {
          rows.forEach((row, i) => row.style.setProperty("--ev", String(i)));
          const spacerAll = section.querySelector<HTMLElement>(".gc-spacer");
          spacerAll?.style.setProperty("--ev", String(rows.length));
          return;
        }

        // Collapsed: hide the early rows, drop a toggle on the top row, and pack
        // the survivors below it.
        rows.forEach((row, i) => {
          if (i < nEarly) {
            row.hidden = true;
          } else {
            // +1 for the toggle row above the first visible screening.
            row.style.setProperty("--ev", String(i - nEarly + 1));
          }
        });

        const toggle = document.createElement("button");
        toggle.type = "button";
        toggle.className =
          "gc-early-toggle cell cell-truncate gc-full text-muted-foreground hover:text-foreground";
        toggle.style.setProperty("--ev", "0");
        const label = root.dataset.showEarlierLabel ?? "Show earlier screenings";
        toggle.innerHTML = `<span class="cell-text">${label}</span>`;
        toggle.addEventListener("click", () => {
          section.setAttribute("data-show-early", "");
          syncAgenda();
        });
        // Insert before the first row so it's first in source order (placement is
        // by --ev, but keeping source order tidy helps AT/tab order).
        section.insertBefore(toggle, rows[0]);

        const spacer = section.querySelector<HTMLElement>(".gc-spacer");
        spacer?.style.setProperty("--ev", String(rows.length - nEarly + 1));
      }

      // Film layout: a small "now" dot per card, at the card's first still-
      // upcoming showtime row. Each card is a masonry column, so the dot must
      // sit at that showtime cell's own grid row AND column (not the band's
      // left edge). We anchor to the showtime's time cell and copy both.
      function drawFilmNowDots(section: HTMLElement, nowKey: string) {
        section.querySelectorAll<HTMLElement>("[data-film-card]").forEach((card) => {
          const times = [...card.querySelectorAll<HTMLElement>(
            ".gc-film-showtime[data-time]:not([hidden])",
          )];
          if (times.length === 0) return;
          // First upcoming showtime in this card. If "now" is before all of
          // them, anchor to the first; if all are past, anchor to the last so
          // the dot always shows (at the start before the first showtime, at
          // the end after the last).
          let target: HTMLElement | null = null;
          for (const cell of times) {
            if (timeSortKey(cell.dataset.time ?? "") > nowKey) {
              target = cell;
              break;
            }
          }
          // Upcoming showtime: the dot sits ON its row (marks "now is just before
          // this showtime"). If every showtime is past, there's no upcoming row
          // to sit on, so anchor to the last showtime and push the dot ONE row
          // below it — otherwise it would overlap the last showtime, and because
          // each card's last showtime is at a different --sr the dots would land
          // at scattered heights across cards.
          const anchor = target ?? times[times.length - 1];
          const cs = getComputedStyle(anchor);
          const rowStart = parseInt(cs.gridRowStart, 10);
          const gridRow = target ? cs.gridRow : String(rowStart + 1);
          // The dot is a section-level grid item that must land on the showtime
          // link's OWN cell. The link spans `--film-left / span --film-width`,
          // so copy the full grid-column shorthand (start AND end), not just
          // gridColumnStart — reading only the start sometimes resolved to a
          // bare/auto value and the dot drifted to the band's left edge.
          const line = document.createElement("div");
          line.className = "now-line cell";
          line.style.gridRow = gridRow;
          line.style.gridColumn = cs.gridColumn;
          section.appendChild(line);
        });
      }

      // Insert a zero-height marker (2px --genre-primary top border) at the grid
      // row of the first still-upcoming event; if all events are past, place it
      // after the last visible event (before the spacer).
      function drawNowLine(section: HTMLElement, nowKey: string) {
        const rows = [...section.querySelectorAll<HTMLElement>(
          ".contents[data-time]:not([hidden])",
        )];
        if (rows.length === 0) return;

        let target: HTMLElement | null = null;
        for (const row of rows) {
          if (timeSortKey(row.dataset.time ?? "") > nowKey) {
            target = row;
            break;
          }
        }

        // Anchor element whose top edge the line sits on. For an upcoming
        // event, that's the event's own first cell. If every event is past,
        // anchor to the spacer, which is already positioned just below the
        // last event in both the desktop (1 row/event) and mobile (2
        // rows/event) layouts — so we never duplicate that row math here.
        const anchor = target
          ? target.querySelector<HTMLElement>(".cell")
          : section.querySelector<HTMLElement>(".gc-spacer");
        if (!anchor) return;
        const gridRowStart = getComputedStyle(anchor).gridRowStart;

        const line = document.createElement("div");
        line.className = "now-line cell gc-full";
        line.style.gridRow = gridRowStart;
        section.appendChild(line);
      }

      // Expose so the film view toggle can re-place dots when it swaps views.
      (window as any).syncAgenda = syncAgenda;

      syncAgenda();
      document.addEventListener("visibilitychange", () => {
        if (!document.hidden) syncAgenda();
      });
      // Recompute the now-line position after the grid settles on resize
      // (desktop/mobile row formulas differ).
      window.addEventListener("resize", syncAgenda);
      // The dots read each cell's resolved grid row/column via getComputedStyle.
      // Those are only correct once Layout's grid script has set --cell /
      // --col-start / the packing-derived tracks. On first paint syncAgenda can
      // run before that settles, so gridColumnStart/gridRowStart come back
      // "auto" and the browser auto-places the dot at the end of the grid (it
      // appears at the bottom of the day until a later relayout). Re-running on
      // the grid's own `gridsync` event places them against settled tracks.
      window.addEventListener("gridsync", syncAgenda);
    </script>
  </body>
</html>
