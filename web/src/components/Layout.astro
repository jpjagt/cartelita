---
import type { Locale } from "@/lib/types";
import "@/styles/global.css";

interface Props {
  locale: Locale;
  title: string;
  canonical: string;
}

const { locale, title, canonical } = Astro.props;
const canonicalUrl = new URL(canonical, Astro.site ?? "https://cartelera.barcelona");
---
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl.href} />
  </head>
  <body class="mx-auto max-w-3xl px-4 font-sans text-gray-900">
    <slot />
    <script>
      const now = new Date();
      const hhmm = now.toTimeString().slice(0, 5);
      const todayIso = now.toISOString().slice(0, 10);
      const yesterdayIso = new Date(now.getFullYear(), now.getMonth(), now.getDate() - 1)
        .toISOString().slice(0, 10);
      const isPostMidnight = hhmm < "05:00";

      document.querySelectorAll<HTMLElement>("section[data-date]").forEach((section) => {
        const date = section.dataset.date ?? "";
        if (date < yesterdayIso) {
          // Fully past days always hidden.
          section.hidden = true;
        } else if (date === yesterdayIso && isPostMidnight) {
          // Previous calendar day: only keep rows with post-midnight times (00:00–04:59).
          section.querySelectorAll<HTMLElement>("tr[data-time]").forEach((row) => {
            const t = row.dataset.time ?? "";
            if (t === "" || t >= "05:00") row.hidden = true;
          });
          // Hide the whole section if nothing remains.
          if (!section.querySelector("tr[data-time]:not([hidden])")) section.hidden = true;
        } else if (date > todayIso) {
          // Future days always visible.
        }
      });
    </script>
  </body>
</html>
