---
import type { Locale } from "@/lib/types"
import "@/styles/global.css"

interface Props {
  locale: Locale
  title: string
  canonical: string
  ogImage?: string
  /** Active genre slug; sets data-genre on <body> so --genre-primary resolves
      page-wide (the now-line and any other genre-tinted chrome read it). */
  genre: string
}

const { locale, title, canonical, ogImage, genre } = Astro.props
const canonicalUrl = new URL(canonical, Astro.site)
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined
---
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl.href} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    {ogImageUrl && (
      <>
        <meta property="og:image" content={ogImageUrl} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:image" content={ogImageUrl} />
      </>
    )}
    <script is:inline>
      if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
        document.documentElement.classList.add("dark");
      }
      window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
        document.documentElement.classList.toggle("dark", e.matches);
      });
    </script>
  </head>
  <body data-genre={genre} class="font-sans bg-background text-foreground">
    <slot />
    <script>
      // One full-bleed grid. JS computes only integers: how many whole
      // columns fit, the content band width in cells (≈1300px), and the
      // band's start column snapped so it's centered to the nearest cell
      // (so the band always lands exactly on gridlines).
      const BAND_PX = 1300;
      function syncGrid() {
        document.querySelectorAll<HTMLElement>(".gridpaper").forEach((grid) => {
          // Round the cell to a whole pixel so grid tracks and the
          // background-image lines sit on identical integer boundaries and
          // can't drift apart across many columns (sub-pixel track widths
          // were the source of the misalignment).
          const base = parseFloat(getComputedStyle(grid).getPropertyValue("--font-size")) || 16;
          const width = grid.clientWidth;
          const cellMultiplier = parseFloat(getComputedStyle(grid).getPropertyValue("--cell-multiplier")) || 1.8
          const target = Math.round(base * cellMultiplier);

          // Mobile (≤640px): no centered band — the content fills the full
          // width. Pick the whole number of cells that fits at the ~32px target,
          // then grow the cell so gridCols × cell === width exactly. The grid
          // tracks and the background-image lines both read this same --cell, so
          // they stay aligned by construction and no sub-cell sliver is left on
          // the right. (cell is fractional here, which is fine: track width and
          // line spacing are identical, so they can't drift apart.)
          let cell, gridCols, bandCells, colStart;
          if (width <= 640) {
            gridCols = Math.max(1, Math.floor(width / target));
            cell = width / gridCols;
            bandCells = gridCols;
            colStart = 1;
          } else {
            // Desktop: fixed square cell, centered band snapped to gridlines.
            cell = target;
            gridCols = Math.max(1, Math.floor(width / cell));
            bandCells = Math.min(gridCols, Math.max(20, Math.round(BAND_PX / cell)));
            colStart = Math.max(1, Math.round((gridCols - bandCells) / 2) + 1);
          }
          grid.style.setProperty("--cell", `${cell}px`);
          grid.style.setProperty("--grid-cols", String(gridCols));
          grid.style.setProperty("--band-cells", String(bandCells));
          grid.style.setProperty("--col-start", String(colStart));
        });
        // Let dependents (e.g. the navbar's cell-snapping) recompute once the
        // grid's --cell/--col-start are settled for this pass.
        window.dispatchEvent(new Event("gridsync"));
      }
      syncGrid();
      window.addEventListener("resize", syncGrid);
      window.addEventListener("load", syncGrid);
    </script>
    <script>
      // Time-aware agenda. Runs on load and whenever the tab is refocused, so a
      // page left open overnight self-corrects. Reasons in the same "logical
      // day" frame as src/lib/agenda.ts: the 05:00 boundary means events at
      // 00:00–04:59 belong to the PREVIOUS evening's section, so section
      // data-date is a *logical* date and we must compare "now" the same way.

      // Mirror agenda.ts timeSortKey: empty first, then ≥05:00, then post-midnight last.
      function timeSortKey(t: string): string {
        if (t === "") return "0";
        if (t >= "05:00") return "1" + t;
        return "2" + t;
      }

      // Local yyyy-mm-dd (NOT toISOString, which shifts to UTC and can lose a
      // day). Section data-date values are local calendar dates, so "now" must
      // be expressed the same way.
      function localDateStr(d: Date): string {
        const y = d.getFullYear();
        const m = String(d.getMonth() + 1).padStart(2, "0");
        const day = String(d.getDate()).padStart(2, "0");
        return `${y}-${m}-${day}`;
      }

      function syncAgenda() {
        const now = new Date();
        const hhmm = now.toTimeString().slice(0, 5);
        const isPostMidnight = hhmm < "05:00";
        // Logical "today": calendar date, rolled back one day before 05:00.
        const nowLogicalDate = localDateStr(
          new Date(now.getFullYear(), now.getMonth(), now.getDate() - (isPostMidnight ? 1 : 0)),
        );
        const nowKey = timeSortKey(hhmm);

        document.querySelectorAll<HTMLElement>(".now-line").forEach((el) => el.remove());

        document.querySelectorAll<HTMLElement>("section[data-date]").forEach((section) => {
          const date = section.dataset.date ?? "";
          section.hidden = false;
          section.querySelectorAll<HTMLElement>("[data-time]").forEach((row) => {
            row.hidden = false;
          });

          if (date < nowLogicalDate) {
            // Fully past logical days hidden (also heals a stale build).
            section.hidden = true;
            return;
          }
          if (date === nowLogicalDate && isPostMidnight) {
            // Current logical day viewed after midnight = yesterday's evening,
            // now over. Keep only post-midnight rows (00:00–04:59).
            section.querySelectorAll<HTMLElement>("[data-time]").forEach((row) => {
              const t = row.dataset.time ?? "";
              if (t === "" || t >= "05:00") row.hidden = true;
            });
            if (!section.querySelector("[data-time]:not([hidden])")) {
              section.hidden = true;
              return;
            }
          }
          if (date === nowLogicalDate) {
            if (section.querySelector("[data-film-card]")) {
              drawFilmNowDots(section, nowKey);
            } else {
              drawNowLine(section, nowKey);
            }
          }
        });
      }

      // Film layout: a small "now" dot per card, at the card's first still-
      // upcoming showtime row. Each card is a masonry column, so the dot must
      // sit at that showtime cell's own grid row AND column (not the band's
      // left edge). We anchor to the showtime's time cell and copy both.
      function drawFilmNowDots(section: HTMLElement, nowKey: string) {
        section.querySelectorAll<HTMLElement>("[data-film-card]").forEach((card) => {
          const times = [...card.querySelectorAll<HTMLElement>(
            ".gc-film-showtime[data-time]:not([hidden])",
          )];
          if (times.length === 0) return;
          // First upcoming showtime in this card; skip if all are still ahead
          // (nothing past yet → no marker, same rule as the row layout).
          let target: HTMLElement | null = null;
          for (const cell of times) {
            if (timeSortKey(cell.dataset.time ?? "") > nowKey) {
              target = cell;
              break;
            }
          }
          if (target === times[0]) return;
          const anchor = target ?? null;
          if (!anchor) return;
          const cs = getComputedStyle(anchor);
          const line = document.createElement("div");
          line.className = "now-line cell";
          line.style.gridRow = cs.gridRowStart;
          line.style.gridColumn = cs.gridColumnStart;
          section.appendChild(line);
        });
      }

      // Insert a zero-height marker (2px --genre-primary top border) at the grid
      // row of the first still-upcoming event; if all events are past, place it
      // after the last visible event (before the spacer).
      function drawNowLine(section: HTMLElement, nowKey: string) {
        const rows = [...section.querySelectorAll<HTMLElement>(
          ".contents[data-time]:not([hidden])",
        )];
        if (rows.length === 0) return;

        let target: HTMLElement | null = null;
        for (const row of rows) {
          if (timeSortKey(row.dataset.time ?? "") > nowKey) {
            target = row;
            break;
          }
        }

        // Don't draw a line above the first event: if "now" is before the day's
        // first event, there's nothing prior to it, so the marker would just sit
        // at the top of the section. Only show it once at least one event is past.
        if (target === rows[0]) return;

        // Anchor element whose top edge the line sits on. For an upcoming
        // event, that's the event's own first cell. If every event is past,
        // anchor to the spacer, which is already positioned just below the
        // last event in both the desktop (1 row/event) and mobile (2
        // rows/event) layouts — so we never duplicate that row math here.
        const anchor = target
          ? target.querySelector<HTMLElement>(".cell")
          : section.querySelector<HTMLElement>(".gc-spacer");
        if (!anchor) return;
        const gridRowStart = getComputedStyle(anchor).gridRowStart;

        const line = document.createElement("div");
        line.className = "now-line cell gc-full";
        line.style.gridRow = gridRowStart;
        section.appendChild(line);
      }

      syncAgenda();
      document.addEventListener("visibilitychange", () => {
        if (!document.hidden) syncAgenda();
      });
      // Recompute the now-line position after the grid settles on resize
      // (desktop/mobile row formulas differ).
      window.addEventListener("resize", syncAgenda);
    </script>
  </body>
</html>
