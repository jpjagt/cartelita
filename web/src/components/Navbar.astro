---
import { getCategoryLists } from "@/lib/queries"
import { LOCALES, DEFAULT_LIST, type Locale } from "@/lib/types"
import { t, categoryName } from "@/i18n"

interface Props {
  locale: Locale
  activeList: string
}

const { locale, activeList } = Astro.props
const strings = t(locale)
const lists = await getCategoryLists()

// SSR placement for the genre links so they don't pile up one-per-cell in the
// top-left corner before the nav script runs. We flow them left-to-right on
// row 3 from col 12 (after the 11-col wordmark), estimating each link's
// cell-span from its label length: 2 cells up to 6 chars, then +1 cell per ~3
// chars (7–9 → 3, 10–12 → 4, 13–15 → 5, …). The nav script remeasures exact
// widths on gridsync/load and overrides these; this is just a close-enough
// first paint. Wrapping is left to JS — we only seed start cols on row 3, which
// is where the desktop layout lands them anyway.
const NAV_START_COL = 16 // col-start(5) + 11-col wordmark
let ssrCol = NAV_START_COL
const navSSR = lists.map((l) => {
  const chars = categoryName(locale, l.slug).length
  const span = Math.max(2, 2 + Math.floor((chars - 4) / 3))
  const startCol = ssrCol
  ssrCol += span
  return { slug: l.slug, startCol, span }
})
const ssrPos = (slug: string) =>
  navSSR.find((n) => n.slug === slug) ?? { startCol: NAV_START_COL, span: 4 }
---
<header class="gridpaper">
  {/* Wordmark. Desktop: 11 cols × 3 rows, font 2.6× the cell. Mobile: 9 cols
      × 2 rows, font 2× (see .navbar-wordmark in global.css). Placement lives
      in CSS so the media query can override it (inline styles can't be). */}
  <a
    href={`/${locale}/${DEFAULT_LIST}`}
    class="cell cell-truncate font-semibold no-underline text-foreground navbar-wordmark"
  ><span class="cell-text">Ca<span class="mr-0.5">r</span>telita</span></a>

  {/* Category nav: JS places links on row 3, flowing right from col 12 (after
      the 11-col wordmark). Wraps up to row 2/1 before the locale zone (last 3 cols). */}
  {lists.map((l) => (
    <a
      data-genre={l.slug}
      data-navlink
      href={`/${locale}/${l.slug}`}
      aria-current={l.slug === activeList ? "page" : undefined}
      style={`grid-column: ${ssrPos(l.slug).startCol} / span ${ssrPos(l.slug).span}; grid-row: 3`}
      class={`cell cell-truncate cell-genre-hover whitespace-nowrap no-underline ${l.primary ? "text-foreground" : "text-muted-foreground"}${l.slug === activeList ? " cell-genre" : ""}`}
    ><span class="cell-text">{categoryName(locale, l.slug)}</span></a>
  ))}

  {/* Locale switcher. Desktop: one cell per locale, top-right row 1,
      right-aligned (inline style below). Mobile: the nav script restacks them
      into the 2 columns right of the 9-col wordmark, across rows 1–2. */}
  {LOCALES.map((lc, i) => (
    <a
      data-locale
      data-locale-index={i}
      href={`/${lc}/${activeList}`}
      aria-current={lc === locale ? "page" : undefined}
      style={`grid-column: calc(var(--c-end) - ${LOCALES.length - i}) / span 1; grid-row: 1`}
      class="cell justify-end text-muted-foreground no-underline hover:text-foreground aria-[current=page]:font-medium aria-[current=page]:text-foreground text-xs sm:text-base"
    >
      <span class="cell-text">{lc.toUpperCase()}</span>
    </a>
  ))}

  <script>
    // The navbar packs links into the one grid by column line. Two layouts:
    //
    //  Desktop (>640px): wordmark 11 cols × rows 1–3. Locales sit top-right on
    //  row 1 (one cell each). Genres flow right from col 12 on row 3, wrapping
    //  UP (3 → 2 → 1) before they reach the locale zone.
    //
    //  Mobile (≤640px): wordmark 9 cols × rows 1–2 (set in CSS). Locales restack
    //  into the 2 cols right of the wordmark across rows 1–2. Genres flow from
    //  the band start on row 3, wrapping DOWN (3 → 4 → 5 …) at the band edge.
    function layoutNav() {
      const header = document.querySelector<HTMLElement>("header.gridpaper");
      if (!header) return;
      const cs = getComputedStyle(header);
      const cell = parseFloat(cs.getPropertyValue("--cell")) || 32;
      const colStart = parseInt(cs.getPropertyValue("--col-start")) || 1;
      const bandCells = parseInt(cs.getPropertyValue("--band-cells")) || 40;
      const bandEnd = colStart + bandCells; // exclusive end line
      const mobile = window.matchMedia("(max-width: 640px)").matches;

      const locales = header.querySelectorAll<HTMLElement>("a[data-locale]");
      const links = header.querySelectorAll<HTMLElement>("a[data-navlink]");
      const spanOf = (a: HTMLElement) => {
        const text = a.querySelector<HTMLElement>(".cell-text") ?? a;
        return Math.max(1, Math.ceil((text.scrollWidth + 6) / cell));
      };

      if (mobile) {
        // Locales: packed into the top-right corner, flush against the band's
        // right edge. Fill right-to-left on row 1; if they don't all fit beside
        // the 9-col wordmark, the overflow wraps onto row 2 (also right-flush).
        const wmEnd = colStart + 9; // first col after the wordmark
        const perRow = Math.max(1, bandEnd - wmEnd); // cols available beside wordmark
        locales.forEach((a, i) => {
          const row = Math.floor(i / perRow);
          const inRow = i % perRow;
          const rowCount = Math.min(perRow, locales.length - row * perRow);
          // Right-align this row: rightmost item sits at bandEnd-1.
          a.style.gridColumn = `${bandEnd - rowCount + inRow} / span 1`;
          a.style.gridRow = `${1 + row}`;
        });
        // Genres: flow from band start on row 3, wrapping down at the band edge.
        let col = colStart;
        let row = 3;
        links.forEach((a) => {
          const span = spanOf(a);
          if (col + span > bandEnd && col > colStart) {
            row += 1;
            col = colStart;
          }
          a.style.gridColumn = `${col} / span ${span}`;
          a.style.gridRow = `${row}`;
          col += span;
        });
        return;
      }

      // Desktop. Restore the per-cell locale placement (a prior mobile pass may
      // have moved them), then flow genres on row 3, wrapping up.
      locales.forEach((a, i) => {
        a.style.gridColumn = `${bandEnd - (locales.length - i)} / span 1`;
        a.style.gridRow = "1";
      });
      const navStart = colStart + 11; // right after the 11-col wordmark
      const localeCol = bandEnd - 3; // last 3 cols reserved for locales
      let col = navStart;
      let row = 3;
      links.forEach((a) => {
        const span = spanOf(a);
        // If this link would overflow into the locale column, wrap up a row.
        if (col + span > localeCol && col > navStart) {
          row = Math.max(1, row - 1);
          col = navStart;
        }
        a.style.gridColumn = `${col} / span ${span}`;
        a.style.gridRow = `${row}`;
        col += span;
      });
    }
    layoutNav();
    window.addEventListener("gridsync", layoutNav);
    window.addEventListener("resize", layoutNav);
    window.addEventListener("load", layoutNav);
  </script>
</header>
