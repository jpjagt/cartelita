---
import type { AgendaEvent, Locale } from "@/lib/types";
import { t } from "@/i18n";
interface Props { event: AgendaEvent; locale: Locale }
const { event, locale } = Astro.props;
const strings = t(locale);
const displayPrice = event.price
  ? (strings.prices[event.price] ?? event.price)
  : "";
---
<tr data-time={event.startTime ?? ""} class="[&>td]:border-b [&>td]:border-gray-100 [&>td]:px-3 [&>td]:py-1.5 [&>td]:align-top">
  <td class="whitespace-nowrap text-gray-600">{event.startTime ?? ""}</td>
  <td>
    <a href={event.sourceUrl} target="_blank" rel="noopener" class="text-inherit no-underline hover:underline">{event.title}</a>
    {event.recurrenceHint && <span class="ml-1 cursor-help text-gray-500" title={event.recurrenceHint}>↻</span>}
  </td>
  <td>{event.venueName}</td>
  <td class="whitespace-nowrap text-gray-600">{displayPrice}</td>
</tr>
