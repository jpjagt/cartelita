---
import type { AgendaEvent, Locale } from "@/lib/types"
import { t } from "@/i18n"
interface Props {
  event: AgendaEvent
  locale: Locale
  genre: string
  /** 0-based index of this event within its day; drives grid-row via --ev. */
  index: number
}
const { event, locale, genre, index } = Astro.props
const strings = t(locale)
const displayPrice = event.price
  ? (strings.prices[event.price] ?? event.price)
  : ""
---
{/* One event = one row of the content band: time · title(grows) · place · price.
   The wrapper carries data-time for the day/row visibility script; it sits
   on the grid via `display: contents` so its children place directly. */}
<div data-time={event.startTime ?? ""} data-genre={genre} style={`--ev: ${index}`} class="contents">
  <time
    class="cell cell-truncate gc-time text-muted-foreground"
  ><span class="cell-text">{event.startTime ?? ""}</span></time>

  {/* The whole title cell IS the link, so the entire row span is clickable. */}
  <a
    data-genre={genre}
    href={event.sourceUrl}
    target="_blank"
    rel="noopener"
    class="cell cell-truncate cell-genre-hover gc-title text-foreground no-underline hover:underline"
  >
    <span class="cell-text">
      {event.title}
      {event.recurrenceHint && <span class="ml-7 cursor-help text-muted-foreground">{event.recurrenceHint}</span>}
    </span>
  </a>

  <div
    class="cell cell-truncate cell-right gc-place"
  ><span class="cell-text">{event.venueName}</span></div>

  <div
    class="cell cell-truncate cell-right gc-price text-muted-foreground"
  ><span class="cell-text">{displayPrice}</span></div>
</div>
