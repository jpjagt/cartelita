---
import type { PackedFilm, Locale } from "@/lib/types"
import { t } from "@/i18n"
interface Props {
  packed: PackedFilm
  locale: Locale
  genre: string
}
const { packed, locale, genre } = Astro.props
const { film } = packed
const strings = t(locale)
const priceOf = (price: string | null) =>
  price ? (strings.prices[price] ?? price) : ""
---
{/* One film card on the shared cell grid. `display: contents` lets the title
   and showtime cells place directly onto the grid via the .gc-film-* classes.
   Packing vars drive the column + row offset per breakpoint (see global.css).
   data-film-card lets the visibility script find cards to place the now-dot. */}
<div
  data-film-card
  class="gc-film-card contents"
  style={`--fcol: ${packed.col3}; --frow: ${packed.row3}; --fcol2: ${packed.col2}; --frow2: ${packed.row2}; --frow1: ${packed.row1}`}
>
  {/* Title spans the card; data-time = latest showtime so the title (and thus
      the whole card) hides only once every showtime is past — the existing
      [data-time] hider does the collapse for free. */}
  <h3
    data-time={film.latestTime}
    class="cell cell-truncate gc-film-title text-foreground font-medium cell-outline-foreground cell-underlined"
  ><span class="cell-text">{film.title}</span></h3>

  {/* One link per showtime spanning the full card width. The time/place/price
      cells are rendered as elements inside it (.gc-st-* sub-cells), so a single
      cell-genre-hover tints the whole showtime row on hover. */}
  {film.showtimes.map((s, sr) => (
    <a
      data-time={s.startTime ?? ""}
      data-genre={genre}
      data-film-showtime
      href={s.sourceUrl}
      target="_blank"
      rel="noopener"
      style={`--sr: ${sr}`}
      class="gc-film-showtime cell-genre-hover no-underline hover:underline"
    >
      <span class="cell cell-truncate gc-st-time text-muted-foreground"
        ><span class="cell-text">{s.startTime ?? ""}</span></span>
      <span class="cell cell-truncate gc-st-place text-foreground"
        ><span class="cell-text">{s.venueName}</span></span>
      <span class="cell cell-truncate cell-right gc-st-price text-muted-foreground"
        ><span class="cell-text">{priceOf(s.price)}</span></span>
    </a>
  ))}
</div>
